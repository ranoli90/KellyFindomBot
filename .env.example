# =============================================================================
# KellyFindomBot — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in values FOR LOCAL DEV ONLY.
# In production (AWS), all secrets are loaded from AWS Secrets Manager.
# NEVER commit .env to git — it is already in .gitignore.
# =============================================================================

# ─── Telegram credentials (from https://my.telegram.org/apps) ───────────────
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here

# Admin Telegram user ID (your numeric account ID)
ADMIN_USER_ID=0

# ─── Payment bot ─────────────────────────────────────────────────────────────
# Token from @BotFather — required for Telegram Stars tribute collection
PAYMENT_BOT_TOKEN=
PAYMENT_BOT_USERNAME=KellyTributeBot

# ─── Persona & monetization ──────────────────────────────────────────────────
# BOT_PERSONA=kelly     → findom mode (Kelly persona, tribute required)
# BOT_PERSONA=heather   → companion mode (original Heather, no gate)
BOT_PERSONA=kelly

# ENABLE_MONETIZATION=true  → real tier gating (FREE/FAN/VIP) — use in prod
# ENABLE_MONETIZATION=false → everyone gets VIP free (local dev / trial)
ENABLE_MONETIZATION=true

# ─── Voice synthesis (ElevenLabs) ────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ─── Monitoring dashboard ────────────────────────────────────────────────────
MONITOR_AUTH_TOKEN=change_me_to_something_secret

# ─── Image generation (ComfyUI — optional) ───────────────────────────────────
COMFYUI_FACE_IMAGE=/app/data/face_source.png

# ─── AWS (production only — not needed for local dev) ───────────────────────
# In production these are provided by the ECS task IAM role (no static creds)
# For local dev that connects to AWS: aws configure OR aws-vault
AWS_REGION=us-east-1
# KELLY_SECRET_NAME=kellyfindombot/prod/secrets
# USE_AWS_SECRETS=true

